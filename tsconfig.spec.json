{
  "extends": "./tsconfig.app.json",
  "include": ["tests/**/*", "tests/**/*.ts", "src/**/*", "src/**/*.vue"],
  "compilerOptions": {
    "composite": true,
    "types": ["vitest/globals", "node"],
    "noUncheckedIndexedAccess": false,
    "paths": {
      "@/*": ["./src/*"]
    },
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.spec.tsbuildinfo"
  }
}
